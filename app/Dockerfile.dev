FROM node:22-alpine

# Habilitar o pnpm nativamente
RUN corepack enable pnpm

WORKDIR /app

# Definir CI=true para evitar prompts interativos do pnpm
ENV CI=true

# Copiar dependências primeiro para aproveitar cache do Docker
COPY package.json pnpm-lock.yaml* pnpm-workspace.yaml* ./

# Instalar as dependências
RUN pnpm install

# Copiar o restante do código
COPY . .

# Expor a porta 3000
EXPOSE 3000

# Variáveis de ambiente para o dev server do Nuxt e polling para hot-reload no docker
ENV HOST=0.0.0.0
ENV PORT=3000
ENV CHOKIDAR_USEPOLLING=true

# Comando para rodar o modo de desenvolvimento
CMD ["pnpm", "run", "dev"]
